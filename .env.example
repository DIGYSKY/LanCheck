# Sous-réseau à scanner (CIDR)
SCAN_SUBNET=192.168.1.0/24
# Interface réseau (optionnel) : eth0, enp0s3, etc. Si vide, arp-scan choisit la défaut.
# SCAN_INTERFACE=eth0
# Intervalle entre deux scans (secondes)
INTERVAL=300
# URL du webhook Discord (Paramètres du serveur → Intégrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY
# Topic ntfy.sh (notifications push, contourne Cloudflare — utile derrière VPN)
# Créer un topic sur https://ntfy.sh puis s'y abonner (app ou navigateur)
NTFY_TOPIC=lan-check-skynas

# Webhook Discord dédié au statut des conteneurs Docker
DOCKER_WEBHOOK_URL=https://discord.com/api/webhooks/AAAA/BBBB
# Intervalle de polling de l'état Docker (secondes)
DOCKER_POLL_INTERVAL=10
# Chemin du socket Docker dans le conteneur
DOCKER_SOCKET_PATH=/var/run/docker.sock
